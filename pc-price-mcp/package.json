{
  "name": "uk-pc-price-mcp",
  "version": "1.0.0",
  "description": "MCP server for UK PC component price and stock tracking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "uk-pc-price-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "web": "node dist/web-standalone.js",
    "dev:web": "tsx src/web-standalone.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
